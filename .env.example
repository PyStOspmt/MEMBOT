# Telegram Bot Token (обов'язково)
BOT_TOKEN=your_bot_token_here

# Максимальний розмір файлу в MB (за замовчуванням 49)
MAX_FILESIZE_MB=49

# Формат завантаження відео (опціонально)
YTDLP_FORMAT=best[height<=720][ext=mp4]/best[height<=720]/best[ext=mp4]/best

# Proxy для yt-dlp (опціонально)
YTDLP_PROXY=

# Шлях до файлу cookies (опціонально)
YTDLP_COOKIEFILE=

# Base64 закодовані cookies (опціонально)
YTDLP_COOKIES_B64=
